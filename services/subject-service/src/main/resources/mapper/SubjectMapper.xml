<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.alvis.exam.subject.repository.SubjectMapper">
  <resultMap id="BaseResultMap" type="com.alvis.exam.subject.domain.Subject">
    <id column="id" property="id"/>
    <result column="name" property="name"/>
    <result column="level" property="level"/>
    <result column="level_name" property="levelName"/>
  </resultMap>
  <sql id="Base_Column_List">id, name, level, level_name</sql>

  <select id="page" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List"/> FROM t_subject
    <where>
      <if test="id != null">AND id = #{id}</if>
      <if test="level != null">AND level = #{level}</if>
    </where>
  </select>

  <select id="findAll" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List"/> FROM t_subject ORDER BY id
  </select>

  <select id="selectById" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List"/> FROM t_subject WHERE id = #{id}
  </select>

  <insert id="insertSelective" parameterType="com.alvis.exam.subject.domain.Subject" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO t_subject (name, level, level_name) VALUES (#{name}, #{level}, #{levelName})
  </insert>

  <update id="updateByPrimaryKeySelective" parameterType="com.alvis.exam.subject.domain.Subject">
    UPDATE t_subject
    <set>
      <if test="name != null">name = #{name},</if>
      <if test="level != null">level = #{level},</if>
      <if test="levelName != null">level_name = #{levelName},</if>
    </set>
    WHERE id = #{id}
  </update>
</mapper>
